{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ElectroCAD Pro",
  "version": "12.0.0",
  "identifier": "com.grigoriu.electrocad-pro",
  "build": {
    "frontendDist": "../src-dist",
    "beforeBuildCommand": "node obfuscate.cjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ElectroCAD Pro v12",
        "width": 1400,
        "height": 900,
        "center": true,
        "resizable": true,
        "maximized": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
